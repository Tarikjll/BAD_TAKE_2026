@model CHEZSWA.ViewModels.FormViewModel

@{
    ViewData["Title"] = "Reservatieformulier";
}

<h2>Reservatieformulier</h2>

<div asp-validation-summary="All" class="text-danger"></div>

<form asp-controller="Reservatie" asp-action="Register" method="post">
    <div class="form-group">
        <label asp-for="Voornaam"></label>
        <input asp-for="Voornaam" class="form-control" />
        <span asp-validation-for="Voornaam" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Familienaam"></label>
        <input asp-for="Familienaam" class="form-control" />
        <span asp-validation-for="Familienaam" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Email"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="BevestigingEmail"></label>
        <input asp-for="BevestigingEmail" class="form-control" />
        <span asp-validation-for="BevestigingEmail" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Datum"></label>
        <input asp-for="Datum" type="date" class="form-control" />
        <span asp-validation-for="Datum" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Tijdstip"></label>
        <select asp-for="Tijdstip" class="form-control"
                asp-items="Html.GetEnumSelectList<CHEZSWA.ViewModels.Tijdstip>()">
        </select>
        <span asp-validation-for="Tijdstip" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="AantalPersonen"></label>
        <input asp-for="AantalPersonen" type="number" min="1" max="10" class="form-control" />
        <span asp-validation-for="AantalPersonen" class="text-danger"></span>
    </div>

    <div class="form-check">
        <input asp-for="Akkoord" type="checkbox" class="form-check-input" />
        <label asp-for="Akkoord" class="form-check-label"></label>
        <span asp-validation-for="Akkoord" class="text-danger"></span>
    </div>

    <div class="form-group mt-3">
        <input type="submit" value="Reserveer" class="btn btn-primary" />
    </div>
</form>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}